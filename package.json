{
  "name": "cve-mapping",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "CVE Exploit Database — maps CVE IDs to public GitHub exploit/PoC repositories. Cyber-dark UI, auto-updated via GitHub Actions.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "scrape": "node scripts/scrape.mjs",
    "scrape:year": "node scripts/scrape.mjs --year",
    "index": "node scripts/build-index.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
